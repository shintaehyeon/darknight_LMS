{
  "manifest_version": 3,
  "name": "다크나이트 - 범용 미디어 다운로더",
  "version": "2.0.0",
  "description": "SNS(트위터/X, 블루스카이, 틱톡, 도우인, 인스타그램, 페이스북), LMS, 웹 사이트의 동영상을 자동으로 감지하여 간편하게 다운로드합니다.",
  "permissions": [
    "webRequest",
    "declarativeNetRequest",
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "다크나이트 실행"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
